generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum VehicleType {
  SEDAN
  SUV
  MINIVAN
  LUXURY_MPV
}

enum BookingStatus {
  PENDING
  DRIVER_CONFIRMED
  DRIVER_STANDBY
  DRIVER_PICKED_UP
  COMPLETED
  CANCELLED
}

enum AttractionBookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  USED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BlogCategory {
  BANGKOK
  PATTAYA
  THAILAND
  PHUKET
  KRABI
  CHIANG_MAI
  CHIANG_RAI
}

enum TierLevel {
  EXPLORER
  ADVENTURER
  NAVIGATOR
  VOYAGER
}

enum LoyaltyTxType {
  EARN
  REDEEM
  EXPIRE
  ADJUST
}

enum PaymentStatus {
  UNPAID
  AWAITING_PAYMENT
  PAID
  FAILED
  REFUNDED
}

enum AdminRole {
  ADMIN
  SUPERADMIN
  SUPPORT
  FINANCE
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String
  name          String
  phone         String?
  loyaltyPoints Int        @default(0)
  tierLevel     TierLevel  @default(EXPLORER)
  preferredPaymentMethod String?   // "CREDIT_CARD" | "PROMPTPAY" | "QR_CODE"
  lastPaymentAt          DateTime?
  whatsappOptOut         Boolean   @default(false)
  // Email verification
  emailVerified          Boolean   @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  wishlist             WishlistItem[]
  attractionBookings   AttractionBooking[]
  passwordResetTokens  PasswordResetToken[]
  loyaltyTransactions  LoyaltyTransaction[]
  tourBookings         TourBooking[]
  pushSubscriptions    PushSubscription[]
  expoTokens           ExpoToken[]
  emailVerifications   EmailVerification[]
  sessions             UserSession[]
  savedRoutes          SavedRoute[]

  @@index([email])
  @@index([createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique // SHA-256 of the raw URL token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tokenHash])
  @@index([userId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model ExpoToken {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())

  @@index([userId])
}

model WishlistItem {
  // TODO: Normalize attractionId — currently encodes type as "tour:<slug>" string hack.
  // Future: add entityType enum (ATTRACTION | TOUR) + entityId field.
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  attractionId   String   // slug or "tour:<slug>"
  attractionName String
  attractionUrl  String?
  itemType       String   @default("attraction") // "attraction" | "tour"
  itemImage      String?
  createdAt      DateTime @default(now())

  @@unique([userId, attractionId])
  @@index([userId])
}

model AttractionBooking {
  id         String @id @default(cuid())
  bookingRef String @unique // e.g. AT-20250001

  // Attraction
  attractionId   String
  attractionName String
  packageName    String
  packageId      String

  // Schedule
  visitDate DateTime @db.Date

  // Tickets
  adultQty   Int   @default(0)
  childQty   Int   @default(0)
  infantQty  Int   @default(0)
  adultPrice Float @default(0)
  childPrice Float @default(0)
  totalPrice Float

  // Customer
  customerName  String
  customerEmail String
  customerPhone String
  notes          String?
  paymentMethod  String?   // "card" | "cash" | "swift" | "crypto"

  // Linked user (optional — guest or logged-in)
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // Payment
  paysoOrderId  String?
  paymentStatus String?  @default("AWAITING_PAYMENT")
  paidAt        DateTime?
  paymentTransactions PaymentTransaction[]

  // Status & audit
  status    AttractionBookingStatus @default(PENDING)
  createdBy String                  @default("user") // "user" | "admin:<name>"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerEmail])
  @@index([userId])
  @@index([visitDate])
  @@index([status])
  @@index([attractionId])
  @@index([packageId])
}

model Booking {
  id         String @id @default(cuid())
  bookingRef String @unique // e.g. WR-20240001

  // Route
  pickupAddress  String
  pickupLat      Float
  pickupLng      Float
  dropoffAddress String
  dropoffLat     Float
  dropoffLng     Float
  distanceKm     Float
  durationMin    Int

  // Schedule
  pickupDate DateTime @db.Date
  pickupTime String   // "14:30"

  // Passengers
  passengers Int
  luggage    Int

  // Vehicle
  vehicleType VehicleType

  // Customer
  customerName  String
  customerEmail String
  customerPhone String
  specialNotes  String?

  // Pricing
  basePrice             Float
  addOnsTotal           Float    @default(0)
  discountAmount        Float    @default(0)
  discountCode          String?  // denormalized code for display (e.g. "WELCOME10")
  discountCodeId        String?  // FK to DiscountCode (soft — not relational to allow code deletion)
  loyaltyPointsRedeemed Int      @default(0)   // points spent at checkout
  loyaltyDiscount       Float    @default(0)   // THB value of redeemed points
  giftVoucherCode       String?                // gift voucher code applied
  giftVoucherDiscount   Float    @default(0)   // THB value of voucher
  totalPrice            Float    // base + addOns + surcharges - discounts

  // Payment
  paymentStatus String?   // "UNPAID" | "AWAITING_PAYMENT" | "PAID" | "FAILED" | "REFUNDED"
  paysoOrderId  String?   // Payso orderId (same as bookingRef usually)
  paymentMethod String?   // "payso_card" | "cash" | "bank_transfer" etc.
  paidAt        DateTime?

  // Driver assignment (optional — set by admin after booking)
  driverId   String?
  driver     Driver?  @relation("DriverBookings", fields: [driverId], references: [id])
  driverName String?  // denormalized for display when driver record may change

  // Status
  currentStatus BookingStatus @default(PENDING)

  // Automation flags
  driverDetailsSentAt DateTime?  // set when 3-hour driver details message is sent

  // Relations
  statusHistory        BookingStatusHistory[]
  bookingAddOns        BookingAddOn[]
  paymentTransactions  PaymentTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([currentStatus])
  @@index([pickupDate])
  @@index([customerEmail])
  @@index([paysoOrderId])
  @@index([driverId])
}

model BookingStatusHistory {
  id        String        @id @default(cuid())
  bookingId String
  booking   Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  status    BookingStatus
  note      String?
  updatedBy String?       // admin name or "system"
  createdAt DateTime      @default(now())

  @@index([bookingId])
}

model PricingRule {
  id            String      @id @default(cuid())
  vehicleType   VehicleType @unique
  name          String
  description   String
  maxPassengers Int
  maxLuggage    Int
  baseFare      Float
  pricePerKm    Float
  imageUrl      String?
  isActive      Boolean     @default(true)
  updatedAt     DateTime    @updatedAt
}

model AddOn {
  id          String       @id @default(cuid())
  name        String
  description String
  price       Float
  icon        String?
  isActive    Boolean      @default(true)
  bookings    BookingAddOn[]
}

model BookingAddOn {
  id        String  @id @default(cuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  addOnId   String
  addOn     AddOn   @relation(fields: [addOnId], references: [id])
  quantity  Int     @default(1)
  unitPrice Float

  @@unique([bookingId, addOnId])
  @@index([bookingId])
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  role         AdminRole @default(ADMIN)
  // Two-factor authentication (TOTP)
  totpSecret   String?  // encrypted TOTP secret
  totpEnabled  Boolean  @default(false)
  backupCodes  String[] // bcrypt-hashed one-time backup codes
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DiscountCode {
  id             String       @id @default(cuid())
  code           String       @unique
  type           DiscountType
  value          Float
  description    String?
  minOrderAmount Float?
  maxUses        Int?
  usedCount      Int          @default(0)
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  newUserOnly    Boolean      @default(false)
  perUserLimit   Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  redemptions    DiscountRedemption[]

  @@index([code])
  @@index([isActive])
}

model DiscountRedemption {
  id             String       @id @default(cuid())
  discountCodeId String
  discountCode   DiscountCode @relation(fields: [discountCodeId], references: [id])
  customerEmail  String
  bookingId      String       @unique
  usedAt         DateTime     @default(now())

  @@index([discountCodeId, customerEmail])
}

enum InquiryStatus {
  NEW
  CONTACTED
  QUOTED
  CONFIRMED
  CANCELLED
}

model Inquiry {
  id                 String        @id @default(cuid())
  ref                String        @unique
  status             InquiryStatus @default(NEW)
  fullName           String
  email              String
  whatsapp           String
  country            String?
  travelDate         String?
  flexibleDate       Boolean       @default(false)
  adults             Int           @default(2)
  children           Int           @default(0)
  destination        String
  multiDestination   Boolean       @default(false)
  tourDuration       String?
  hotelCategory      String?
  budgetRange        String?
  transportType      String?
  activities         Json?
  tourPreferences    String?
  specialRequests    String?
  source             String?
  adminNotes         String?
  lastContactedAt    DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

enum TourBookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model TourBooking {
  id            String            @id @default(cuid())
  bookingRef    String            @unique
  tourSlug      String
  tourTitle     String
  optionLabel   String?
  tourTime      String?           // e.g. "08:00"
  tourOptionId  String?           // option ID from tours catalogue
  bookingDate   DateTime
  adultQty      Int
  childQty      Int               @default(0)
  adultPrice    Float
  childPrice    Float             @default(0)
  totalPrice    Float
  customerName  String
  customerEmail String
  customerPhone String
  status        TourBookingStatus @default(CONFIRMED)
  userId        String?
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  notes         String?
  paymentMethod String?
  paymentStatus String?           // "UNPAID" | "AWAITING_PAYMENT" | "PAID" | "FAILED"
  paysoOrderId  String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  statusHistory TourBookingStatusHistory[]

  @@index([customerEmail])
  @@index([bookingDate])
  @@index([status])
  @@index([paysoOrderId])
  @@index([tourSlug])
}

model TourBookingStatusHistory {
  id            String      @id @default(cuid())
  tourBookingId String
  tourBooking   TourBooking @relation(fields: [tourBookingId], references: [id], onDelete: Cascade)
  status        String
  note          String?
  updatedBy     String      @default("system")
  createdAt     DateTime    @default(now())

  @@index([tourBookingId])
}

// ─── Reviews ──────────────────────────────────────────────────────────────────

enum ReviewEntityType {
  TOUR
  ATTRACTION
  TRANSFER
}

model Review {
  id         String           @id @default(cuid())
  entityType ReviewEntityType
  entityId   String           // tourSlug | attractionSlug | bookingRef
  entityName String           // display name of the thing reviewed

  rating     Int              // 1–5
  title      String?
  body       String           @db.Text

  // Reviewer
  authorName  String
  authorEmail String           // used to verify ownership, not shown publicly
  verified    Boolean          @default(false) // set to true after booking lookup

  // Moderation
  isPublished Boolean          @default(false) // admin approves before showing
  adminNotes  String?

  // Link to user account if they were logged in
  userId      String?

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([entityType, entityId, isPublished])
  @@index([authorEmail])
  @@index([isPublished])
}

model AttractionListing {
  id            String              @id @default(cuid())
  slug          String              @unique
  name          String
  location      String
  category      String
  rating        Float               @default(4.5)
  reviewCount   Int                 @default(0)
  price         Float
  originalPrice Float?
  badge         String?
  gradient      String              @default("from-brand-600 to-brand-400")
  emoji         String              @default("🎫")
  href          String              @default("#")
  isActive      Boolean             @default(true)
  sortOrder     Int                 @default(0)
  featureImage  String?
  // Rich content fields
  overview      String?
  highlights    Json?
  included      Json?
  excluded      Json?
  infoItems     Json?
  expectSteps   Json?
  faqs          Json?
  gallery       Json?
  metaTitle     String?
  metaDesc      String?
  packages      AttractionPackage[]
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([category])
  @@index([isActive])
}

// ─── Blog ─────────────────────────────────────────────────────────────────────

model BlogPost {
  id             String       @id @default(cuid())
  slug           String       @unique
  title          String
  excerpt        String       @db.Text
  content        String       @db.Text
  featuredImage  String?

  category       BlogCategory
  tags           String[]

  status         BlogStatus   @default(DRAFT)
  publishedAt    DateTime?

  // SEO
  seoTitle       String?
  seoDescription String?

  // Author
  authorName     String       @default("Werest Travel")
  authorTitle    String?

  // Structured content blocks (JSON arrays)
  faqs           Json?        // [{ q: string; a: string }]
  ctaBlocks      Json?        // [{ title: string; description: string; href: string; buttonLabel: string }]
  relatedServices Json?       // [{ title: string; href: string; description?: string }]
  relatedSlugs   String[]     // slugs of related BlogPost records

  readingTimeMin Int          @default(5)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status])
  @@index([category])
  @@index([publishedAt])
}

// ─── Tours ────────────────────────────────────────────────────────────────────

model Tour {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  subtitle     String?
  location     String
  cities       String[] // destination keywords for search matching
  duration     String
  maxGroupSize Int      @default(15)
  languages    String[]
  rating       Float    @default(5.0)
  reviewCount  Int      @default(0)
  category     String   // day-trip | cultural | adventure | food | nature | water
  badge        String?  // Best Seller | Top Rated | New
  images       String[]
  highlights   String[]
  description  String   @db.Text
  includes     String[]
  excludes     String[]
  itinerary    Json?    // TourItineraryItem[]
  options      Json?    // TourOption[]
  meetingPoint String?
  importantInfo String[]
  reviews      Json?    // TourReview[]
  faqs               Json?
  cancellationPolicy String?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Categorization
  tags               String[]
  primaryLocation    String             @default("Bangkok")
  subLocation        String?
  multiCategories    String[]

  // Pricing
  priceFrom          Float              @default(0)
  discountPrice      Float?

  // Feature flags
  isFeatured         Boolean            @default(false)
  isPopular          Boolean            @default(false)
  isTrending         Boolean            @default(false)
  homepageVisible    Boolean            @default(true)
  instantConfirmation Boolean           @default(true)
  availabilityStatus  String            @default("available")

  // SEO
  metaTitle          String?
  metaDesc           String?

  @@index([category])
  @@index([isActive])
  @@index([slug])
  @@index([primaryLocation])
  @@index([isFeatured])
}

// ─── Drivers & Vehicles ───────────────────────────────────────────────────────

model Driver {
  id             String      @id @default(cuid())
  name           String
  phone          String      @unique
  licenseNumber  String?
  languages      String[]    // e.g. ["English", "Thai"]
  photoUrl       String?
  isActive       Boolean     @default(true)
  isOnline       Boolean     @default(false)  // currently on duty
  currentLat     Float?                        // last known GPS position
  currentLng     Float?
  rating         Float       @default(5.0)
  totalTrips     Int         @default(0)
  notes          String?

  vehicles        Vehicle[]
  bookings        Booking[]        @relation("DriverBookings")
  charterBookings CharterBooking[] @relation("DriverCharterBookings")
  locations       DriverLocation[] @relation("DriverLocations")
  authTokens      DriverAuthToken[] @relation("DriverTokens")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([isOnline])
  @@index([phone])
}

model Vehicle {
  id          String      @id @default(cuid())
  plateNumber String      @unique
  make        String      // e.g. "Toyota"
  model       String      // e.g. "Alphard"
  year        Int
  vehicleType VehicleType
  capacity    Int         @default(4)
  color       String?
  photoUrl    String?
  isActive    Boolean     @default(true)

  driverId    String?
  driver      Driver?     @relation(fields: [driverId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleType])
  @@index([isActive])
  @@index([driverId])
}

model PaymentTransaction {
  id                  String            @id @default(cuid())
  bookingId           String?
  booking             Booking?          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  attractionBookingId String?
  attractionBooking   AttractionBooking? @relation(fields: [attractionBookingId], references: [id], onDelete: Cascade)
  paysoOrderId        String
  paysoTxnId          String?
  paymentUrl          String?
  amount              Float
  currency            String            @default("THB")
  status              String            @default("AWAITING_PAYMENT") // AWAITING_PAYMENT | PAID | FAILED | REFUNDED
  rawWebhook          Json?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([bookingId])
  @@index([attractionBookingId])
  @@index([paysoOrderId])
}

model LoyaltyTransaction {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  points      Int
  type        LoyaltyTxType
  description String
  bookingRef  String?
  createdAt   DateTime      @default(now())

  @@index([userId])
  @@index([bookingRef])
}

model AttractionPackage {
  id            String            @id @default(cuid())
  attractionId  String
  attraction    AttractionListing @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  adultPrice    Float
  adultOriginal Float?
  childPrice    Float             @default(0)
  childOriginal Float?
  infantPrice   Float             @default(0)
  popular       Boolean           @default(false)
  badge         String?
  includes      Json?
  isActive      Boolean           @default(true)
  sortOrder     Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([attractionId])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("website")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}

model TourNotifyRequest {
  id        String   @id @default(cuid())
  email     String
  tourSlug  String
  notified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([tourSlug])
  @@index([email])
  @@index([notified])
}

model GiftVoucher {
  id               String    @id @default(cuid())
  code             String    @unique
  value            Float
  recipientName    String?
  recipientEmail   String?
  purchaserEmail   String?
  message          String?
  isUsed           Boolean   @default(false)
  usedAt           DateTime?
  usedByEmail      String?
  usedOnBookingRef String?
  expiresAt        DateTime?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// ─── Dynamic Pricing Rules ────────────────────────────────────────────────────

model DynamicPricingRule {
  id          String       @id @default(cuid())
  name        String       // e.g. "Songkran Surge", "Late Night", "Weekend Discount"
  description String?
  ruleType    String       // "SURGE" | "DISCOUNT" | "FIXED_SURCHARGE"
  vehicleType VehicleType? // null = applies to all vehicles

  // Adjustment
  multiplier  Float        @default(1.0)  // 1.3 = +30%, 0.85 = -15%
  flatAmount  Float?                      // alternative: fixed THB add/subtract

  // Time conditions (empty array / null = all)
  daysOfWeek  Int[]        // 0=Sun … 6=Sat
  startHour   Int?         // 0–23 (null = no time restriction)
  endHour     Int?         // 0–23

  // Date range conditions
  startDate   DateTime?
  endDate     DateTime?

  // Route keyword matching (optional)
  pickupKeyword   String?  // partial match, e.g. "Airport" / "Suvarnabhumi"
  dropoffKeyword  String?

  isActive    Boolean      @default(true)
  priority    Int          @default(0)   // higher = evaluated first
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([isActive, priority])
}

// ─── Charter / Multi-Stop Bookings ───────────────────────────────────────────

enum CharterType {
  HOURLY
  MULTI_STOP
}

model CharterBooking {
  id          String      @id @default(cuid())
  bookingRef  String      @unique
  charterType CharterType

  // Vehicle
  vehicleType VehicleType

  // Schedule
  startDate   DateTime    @db.Date
  startTime   String      // "09:00"
  durationHours Float?    // for HOURLY type

  // Stops (JSON array: [{address, lat, lng, note, order}])
  startAddress  String
  startLat      Float
  startLng      Float
  stops         Json       @default("[]")
  endAddress    String?
  endLat        Float?
  endLng        Float?

  // Customer
  customerName  String
  customerEmail String
  customerPhone String
  passengers    Int        @default(1)
  specialNotes  String?

  // Pricing
  hourlyRate    Float?
  distanceKm    Float      @default(0)
  basePrice     Float
  totalPrice    Float

  // Payment
  paymentStatus String     @default("AWAITING_PAYMENT")
  paysoOrderId  String?
  paymentMethod String?
  paidAt        DateTime?

  // Driver
  driverId      String?
  driver        Driver?    @relation("DriverCharterBookings", fields: [driverId], references: [id])
  driverName    String?

  // Status
  currentStatus BookingStatus @default(PENDING)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([customerEmail])
  @@index([startDate])
  @@index([currentStatus])
  @@index([paysoOrderId])
}

// ─── Live Driver Tracking ─────────────────────────────────────────────────────

model DriverLocation {
  id        String   @id @default(cuid())
  driverId  String
  driver    Driver   @relation("DriverLocations", fields: [driverId], references: [id], onDelete: Cascade)
  bookingId String?  // booking currently being served
  lat       Float
  lng       Float
  heading   Float?   // degrees 0–360
  speed     Float?   // km/h
  createdAt DateTime @default(now())

  @@index([driverId])
  @@index([bookingId])
  @@index([createdAt])
}

// ─── Driver PWA Auth ──────────────────────────────────────────────────────────

model DriverAuthToken {
  id        String   @id @default(cuid())
  driverId  String
  driver    Driver   @relation("DriverTokens", fields: [driverId], references: [id], onDelete: Cascade)
  tokenHash String   @unique  // SHA-256 of raw bearer token
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([tokenHash])
  @@index([driverId])
}

// ─── WhatsApp Booking Flow ────────────────────────────────────────────────────

enum WhatsAppStep {
  GREETING
  PICKUP
  DROPOFF
  DATE
  TIME
  PASSENGERS
  VEHICLE
  CONFIRM
  PAYMENT
  DONE
  CANCELLED
}

model WhatsAppSession {
  id          String       @id @default(cuid())
  phone       String       @unique  // international format e.g. "66812345678"
  step        WhatsAppStep @default(GREETING)
  data        Json         @default("{}")   // accumulated booking data
  bookingRef  String?      // set once booking is created
  lastMessage DateTime     @updatedAt
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([phone])
  @@index([lastMessage])
}

// ─── Email Journey Automation ─────────────────────────────────────────────────

model EmailJourneyLog {
  id          String   @id @default(cuid())
  email       String
  bookingRef  String
  journeyType String   // "POST_TRIP_REVIEW" | "RE_ENGAGEMENT" | "ANNIVERSARY"
  sentAt      DateTime @default(now())

  @@unique([bookingRef, journeyType])
  @@index([email])
  @@index([sentAt])
}

// ─── Currency Rates Cache ─────────────────────────────────────────────────────

model CurrencyRate {
  id         String   @id @default(cuid())
  base       String   @default("THB")
  rates      Json     // { USD: 0.027, EUR: 0.025, GBP: 0.021, CNY: 0.197, JPY: 4.1 }
  fetchedAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  // @@unique([base]) -- pending data deduplication in CurrencyRate table
  @@index([fetchedAt])
}

model ItineraryPreset {
  id           String   @id @default(cuid())
  name         String
  description  String?
  category     String   // "adventure" | "cultural" | "beach" | "family" | "honeymoon" | "luxury"
  destinations String[]
  days         Int
  thumbnail    String?
  dayBlocks    Json     @default("[]")
  inclusions   Json     @default("[]")
  exclusions   Json     @default("[]")
  terms        String?  @db.Text
  tags         String[]
  usageCount   Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Email Verification ───────────────────────────────────────────────────────

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique // SHA-256 of the raw URL token
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([tokenHash])
  @@index([userId])
}

// ─── User Sessions (for revocation) ──────────────────────────────────────────

model UserSession {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jti       String    @unique // JWT ID claim — matches token
  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime? // null = active

  @@index([userId])
  @@index([jti])
  @@index([userId, revokedAt])
}

// ─── Saved Routes ─────────────────────────────────────────────────────────────

model SavedRoute {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  label          String      // e.g. "Home → Airport"
  pickupAddress  String
  pickupLat      Float?
  pickupLng      Float?
  dropoffAddress String
  dropoffLat     Float?
  dropoffLng     Float?
  vehicleType    VehicleType?
  createdAt      DateTime    @default(now())

  @@index([userId])
}

// ─── Admin Audit Log ──────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String   // AdminUser.id
  adminEmail String
  action     String   // e.g. "BOOKING_STATUS_UPDATE", "DRIVER_ASSIGN", "REFUND_APPROVE"
  entityType String   // "Booking" | "TourBooking" | "User" | "Driver" | etc.
  entityId   String?
  before     Json?    // snapshot before change
  after      Json?    // snapshot after change
  ip         String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([adminEmail])
  @@index([entityType, entityId])
  @@index([createdAt])
}

// ─── Refunds ─────────────────────────────────────────────────────────────────

enum RefundStatus {
  PENDING
  APPROVED
  PROCESSED
  REJECTED
}

model Refund {
  id           String       @id @default(cuid())
  bookingRef   String       // display reference (e.g. WRTF-20250001)
  bookingType  String       // "transfer" | "tour" | "attraction" | "charter"
  bookingId    String
  amount       Float
  currency     String       @default("THB")
  reason       String
  status       RefundStatus @default(PENDING)
  processedBy  String?      // admin name
  processedAt  DateTime?
  paysoRefId   String?      // Payso refund transaction ID if applicable
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([bookingRef])
  @@index([bookingId])
  @@index([status])
  @@index([createdAt])
}

// ─── Tour Availability ────────────────────────────────────────────────────────

model TourAvailability {
  id          String   @id @default(cuid())
  tourSlug    String
  date        DateTime @db.Date
  optionId    String?  // null = applies to all options
  maxCapacity Int      @default(15)
  booked      Int      @default(0)
  isBlocked   Boolean  @default(false) // admin can block a date
  note        String?  // e.g. "Holiday — closed"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tourSlug, date, optionId])
  @@index([tourSlug, date])
}

// ─── Abandoned Bookings ───────────────────────────────────────────────────────

model AbandonedBooking {
  id            String    @id @default(cuid())
  sessionToken  String    @unique // random token stored in browser cookie
  bookingType   String    // "transfer" | "tour"
  step          String    // "vehicle_selected" | "details" | "payment"
  data          Json      // partial booking data
  customerEmail String?
  customerName  String?
  recoveryEmailSentAt DateTime?
  recoveredAt   DateTime? // set when user completes the booking
  expiresAt     DateTime
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([customerEmail])
  @@index([sessionToken])
  @@index([expiresAt])
}

model GeneratedItinerary {
  id             String    @id @default(cuid())
  ref            String    @unique
  title          String
  subtitle       String?
  clientName     String?
  clientEmail    String?
  destination    String
  destinations   String[]  @default([])
  startDate      DateTime?
  endDate        DateTime?
  travelers      Int       @default(2)
  hotelCategory  String    @default("standard")
  language       String    @default("en")
  status         String    @default("draft")
  overview       String?   @db.Text
  highlights     Json      @default("[]")
  dayBlocks      Json      @default("[]")
  inclusions     Json      @default("[]")
  exclusions     Json      @default("[]")
  terms          String?   @db.Text
  importantNotes String?   @db.Text
  pricingLines   Json      @default("[]")
  totalPrice     Float?
  currency       String    @default("THB")
  presetId       String?
  aiPromptUsed   String?   @db.Text
  adminNotes     String?
  exportedAt     DateTime?
  sentAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
