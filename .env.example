# ─────────────────────────────────────────────
# Werest Travel – Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# Database (PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/werest_travel"

# Google Maps (browser-safe – set HTTP referrer restrictions in Google Console)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# Google Maps Server-side (Distance Matrix with traffic)
GOOGLE_MAPS_SERVER_API_KEY="YOUR_SERVER_GOOGLE_MAPS_API_KEY"

# WhatsApp Business API (via Meta or Twilio)
WHATSAPP_PHONE_NUMBER_ID="YOUR_WHATSAPP_PHONE_NUMBER_ID"
WHATSAPP_ACCESS_TOKEN="YOUR_WHATSAPP_ACCESS_TOKEN"
WHATSAPP_ADMIN_PHONE="66XXXXXXXXX"   # Admin's WhatsApp number (country code + number)

# Admin JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET="your-very-long-random-secret-here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_COMPANY_NAME="Werest Travel"
NEXT_PUBLIC_COMPANY_PHONE="+66 XX XXX XXXX"
