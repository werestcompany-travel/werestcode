# ─────────────────────────────────────────────
# Werest Travel – Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# ── Database (PostgreSQL / Supabase) ─────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/werest_travel"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/werest_travel"   # Supabase direct URL for migrations

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_COMPANY_NAME="Werest Travel"
NEXT_PUBLIC_COMPANY_PHONE="+66 XX XXX XXXX"
NEXT_PUBLIC_EMAIL_DOMAIN="werest.com"      # Used as the From address domain for emails

# ── Auth (generate with: openssl rand -base64 32) ────────────────────────────
JWT_SECRET="your-very-long-random-secret-here"
CRON_SECRET="your-random-secret-here"           # Vercel passes this as Authorization: Bearer <secret> for cron jobs

# ── Google Maps ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"    # Browser key (restrict by HTTP referrer)
GOOGLE_MAPS_SERVER_API_KEY="YOUR_SERVER_GOOGLE_MAPS_API_KEY"  # Server key (restrict by IP)

# ── WhatsApp Business API (Meta Graph API) ────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID="YOUR_WHATSAPP_PHONE_NUMBER_ID"
WHATSAPP_ACCESS_TOKEN="YOUR_WHATSAPP_ACCESS_TOKEN"
WHATSAPP_ADMIN_PHONE="66XXXXXXXXX"   # Admin's WhatsApp number (country code + number, no +)

# ── Email (Resend — https://resend.com) ───────────────────────────────────────
# Required for: booking confirmations, password reset, attraction confirmations
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# ── Error Tracking (Sentry — https://sentry.io) ───────────────────────────────
NEXT_PUBLIC_SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"
SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"           # Same DSN, server-only variable
SENTRY_AUTH_TOKEN="sntrys_xxxxxxxxxxxx"                          # For source map uploads in CI

# ── Rate Limiting (optional — Upstash Redis for multi-instance deployments) ───
# Leave empty to use the built-in in-memory rate limiter (single-instance only)
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxxxxxxxxxxx"

# ── Analytics (optional) ──────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
