# ─────────────────────────────────────────────
# Werest Travel – Environment Variables
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# ── Database (PostgreSQL / Supabase) ─────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/werest_travel"
DIRECT_URL="postgresql://USER:PASSWORD@localhost:5432/werest_travel"   # Supabase direct URL for migrations

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="https://www.werest.com"
NEXT_PUBLIC_COMPANY_NAME="Werest Travel"
NEXT_PUBLIC_COMPANY_PHONE="+66 XX XXX XXXX"
NEXT_PUBLIC_EMAIL_DOMAIN="werest.com"      # Used as the From address domain for emails

# ── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED — app will crash on boot if JWT_SECRET is missing (prevents insecure fallback)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-very-long-random-secret-here-minimum-64-chars"
# Vercel passes CRON_SECRET as: Authorization: Bearer <secret>
# Admin dashboard manual triggers must also use the Authorization header (query params log secrets)
CRON_SECRET="your-random-secret-here"

# ── Google Maps ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"    # Browser key (restrict by HTTP referrer)
GOOGLE_MAPS_SERVER_API_KEY="YOUR_SERVER_GOOGLE_MAPS_API_KEY"  # Server key (restrict by IP)

# ── WhatsApp Business API (Meta Graph API) ────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID="YOUR_WHATSAPP_PHONE_NUMBER_ID"
WHATSAPP_ACCESS_TOKEN="YOUR_WHATSAPP_ACCESS_TOKEN"
WHATSAPP_ADMIN_PHONE="66XXXXXXXXX"   # Admin's WhatsApp number (country code + number, no +)

# ── Email (Resend — https://resend.com) ───────────────────────────────────────
# Required for: booking confirmations, password reset, attraction confirmations
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"

# ── Error Tracking (Sentry — https://sentry.io) ───────────────────────────────
NEXT_PUBLIC_SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"
SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"           # Same DSN, server-only variable
SENTRY_AUTH_TOKEN="sntrys_xxxxxxxxxxxx"                          # For source map uploads in CI

# ── WhatsApp (customer-facing floating button) ────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=66819519191

# ── Instagram (optional — enables real Instagram feed in SocialFeed component) ─
# Get from https://developers.facebook.com/docs/instagram-basic-display-api
# Leave blank to use static travel inspiration images
INSTAGRAM_ACCESS_TOKEN=

# ── Rate Limiting (optional — Upstash Redis for multi-instance deployments) ───
# Leave empty to use the built-in in-memory rate limiter (single-instance only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Analytics (optional) ──────────────────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"
# Microsoft Clarity heatmaps & session recordings — free at clarity.microsoft.com
NEXT_PUBLIC_CLARITY_ID=""

# ── Payment (Payso) ───────────────────────────────────────────────────────────
# Get credentials from your Payso merchant dashboard
PAYSO_API_KEY="your-payso-api-key"
PAYSO_SECRET_KEY="your-payso-secret-key"
PAYSO_MERCHANT_ID="your-payso-merchant-id"
PAYSO_API_URL="https://api.payso.co.th"       # Change to sandbox URL for testing
PAYSO_SANDBOX=false

# ── Seeding (used only during prisma db seed — not needed in production runtime)
SEED_ADMIN_EMAIL=admin@werest.com
SEED_ADMIN_PASSWORD=ChangeMeBeforeSeeding!

# ── Email (partner notifications) ─────────────────────────────────────────────
EMAIL_FROM=hello@werest.com
EMAIL_ADMIN=werestcompany@gmail.com

# ── Image Uploads (Vercel Blob — production) ────────────────────────────────
# Get from: Vercel Dashboard → Storage → Blob → Create Store → .env.local tab
# Without this, uploads save to public/uploads/ (local dev only)
BLOB_READ_WRITE_TOKEN=""

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://yourdomain.com/api/user/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── AI Chat Concierge (OpenAI) ────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"   # Optional — defaults to gpt-4o-mini

# ── WhatsApp Booking Bot ───────────────────────────────────────────────────────
# Set this token in Meta for Developers → WhatsApp → Configuration → Webhook Verify Token
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your-random-verify-token-here"
# Webhook URL to register with Meta: https://yourdomain.com/api/whatsapp/webhook

# ── Dynamic Pricing ───────────────────────────────────────────────────────────
# No extra env vars needed — rules managed entirely in admin panel

# ── Multi-Currency (live rates) ───────────────────────────────────────────────
# Uses open.er-api.com (free, no key needed) — rates cached in DB every 4 hours
# No extra env vars needed

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="BExamplePublicKeyBase64..."
VAPID_PRIVATE_KEY="ExamplePrivateKeyBase64..."
VAPID_SUBJECT="mailto:hello@werest.com"
